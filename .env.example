# RunOwl — Environment Variables
# Copy this file to .env and fill in your values.
# Lines starting with # are comments and are ignored.

# ── Required ───────────────────────────────────────────────────────────────────

# Google Gemini API key
# Get one at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ── Recommended ────────────────────────────────────────────────────────────────

# GitHub Personal Access Token
# Required for: private repos, higher rate limits (5,000 req/hr vs 60)
# Scopes needed: repo (private) or public_repo (public only)
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# ── Webhook server ─────────────────────────────────────────────────────────────

# Secret used to verify GitHub webhook payloads (HMAC-SHA256)
# Generate with: openssl rand -hex 32
# Must match the secret configured in your GitHub webhook settings
GITHUB_WEBHOOK_SECRET=

# GitHub App credentials (alternative to GITHUB_TOKEN for org-wide installs)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=

# ── Paid features ──────────────────────────────────────────────────────────────

# RunOwl license key — unlocks Team tier features:
#   - Deep OWASP security analysis
#   - SOLID / architecture analysis
#   - GitHub Check Runs integration
# Get a key at: https://runowl.ai/pricing
RUNOWL_API_KEY=

# Explicit tier override (overrides API key detection)
# Values: free | team | business | enterprise
RUNOWL_TIER=free

# ── Server configuration ───────────────────────────────────────────────────────

HOST=0.0.0.0
PORT=8000
ENV=development
